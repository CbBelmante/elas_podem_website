{
  "name": "elas_podem_website",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "bun scripts/postinstall.ts",
    "cbcomponentsLinkLocal": "bun scripts/linkLocal.ts",
    "cbcomponentsLinkRemote": "bun scripts/linkRemote.ts",
    "cleanViteCache": "rm -rf .nuxt .output .vite node_modules/.vite node_modules/.cache",
    "lint": "eslint .",
    "lintFix": "eslint . --fix",
    "format": "eslint . --fix",
    "format:check": "eslint . --max-warnings 0",
    "deploy": "npm run generate && npx firebase-tools deploy --only hosting",
    "deployPreview": "npm run generate && npx serve .output/public",
    "seedAdmin": "npx tsx --no-deprecation scripts/seedAdmin.ts",
    "killPort": "bun scripts/killPort.ts",
    "prepare": "husky",
    "lintStaged": "lint-staged"
  },
  "config": {
    "useCbLocal": true
  },
  "lint-staged": {
    "*.{vue,js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "firebase": "^12.9.0",
    "lucide-vue-next": "^0.563.0",
    "nuxt": "^4.3.0",
    "reka-ui": "^2.7.0",
    "vue": "^3.5.27",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.2.1",
    "@nuxt/eslint": "^1.13.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.2",
    "firebase-admin": "^13.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "vue-tsc": "^3.2.5"
  }
}
